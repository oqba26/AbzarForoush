<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- خروج دیتابیس مالی از بک‌آپ ابری (گوگل درایو) -->
        <exclude domain="database" path="abzar_database"/>
        <exclude domain="database" path="abzar_database-shm"/>
        <exclude domain="database" path="abzar_database-wal"/>
    </cloud-backup>

    <device-transfer>
        <!-- هنگام انتقال مستقیم گوشی به گوشی، می‌توان دیتابیس را هم منتقل کرد -->
        <!-- اما برای امنیت بیشتر، اینجا هم می‌توانیم مثل بالا محدود کنیم -->
        <exclude domain="database" path="abzar_database"/>
        <exclude domain="database" path="abzar_database-shm"/>
        <exclude domain="database" path="abzar_database-wal"/>
    </device-transfer>
</data-extraction-rules>